    add16 instance1 (.a(a[15:0]), .b(b[15:0]), .cin(1'b0), .cout(x), .sum(sum[15:0]));
    add16 instance2 (.a(a[31:16]), .b(b[31:16]), .cin(1'b0), .sum(y));
    add16 instance3 (.a(a[31:16]), .b(b[31:16]), .cin(1'b1), .sum(z));
    
