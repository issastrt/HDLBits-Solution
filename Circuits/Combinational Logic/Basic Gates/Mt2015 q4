module top_module (input x, input y, output z);
    wire a, b, c, d, e, f;
    
    A A1(.x(x), .y(y), .z(a));
    B B1(.x(x), .y(y), .z(b));
    A A2(.x(x), .y(y), .z(c));
    B B2(.x(x), .y(y), .z(d));
    
    assign e = a|b;
    assign f = c&d;
    assign z = e^f;

endmodule

module A (input x, input y, output z);
    assign z = (x^y) & x;
endmodule

module B ( input x, input y, output z );
    assign z = ~(x^y);
endmodule

